# Copy this file to .env and fill in your own keys

# Anthropic (Claude) API key — powers CV building, cover letters, and the career advisor
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Apify — used for job/company scraping tasks
# Get a token at: https://apify.com
APIFY_TOKEN=your_apify_token_here

# Adzuna job search API — get credentials at: https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
